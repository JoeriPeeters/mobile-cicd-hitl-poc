        <mxCell id="p11" value="⚙️/🧑 11. Staged / phased rollout&#10;monitor crash-free rate + metrics&#10;→ advance or halt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="1025" width="260" height="60" as="geometry" />
