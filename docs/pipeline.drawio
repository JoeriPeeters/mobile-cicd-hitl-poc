        <mxCell id="p6" value="🧑 6. Cut a release (tag / release manager)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="600" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="p7" value="⚙️ 7. Build: EAS Build / fastlane gym&#10;(macOS runner, signing via match / EAS creds)&#10;→ .ipa/.aab → TestFlight / Play internal track" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="665" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="pg2" value="🧑 GATE 2 — RELEASE APPROVAL&#10;`production` environment, required reviewers&#10;(the irreversible step)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#b85450;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="745" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="p9" value="⚙️ 9. Submit: App Store Connect API /&#10;Google Play Developer API&#10;(fastlane deliver/supply · eas submit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="845" width="260" height="60" as="geometry" />
        </mxCell>
