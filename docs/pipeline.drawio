<mxfile host="app.diagrams.net" type="device">
  <diagram name="HITL CI-CD Pipeline" id="hitl-pipeline">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="HITL CI/CD Pipeline — React Native (Expo)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="520" height="30" as="geometry" />
        </mxCell>

        <!-- Legend -->
        <mxCell id="legTitle" value="Legend" style="text;html=1;fontSize=12;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legH" value="🧑 Human-in-the-loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="115" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legA" value="🤖 AI agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legAuto" value="⚙️ Automated (CI / workflow)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="185" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legExt" value="🍏 External (Apple / Google)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legGate" value="HITL GATE (human approves)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#b85450;strokeWidth=3;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="255" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legMock" value="〔MOCK〕 dashed = mocked seam" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- ============ BUILD SIDE ============ -->
        <mxCell id="buildHdr" value="BUILD SIDE  (code → merge)" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=#eeeeee;rounded=1;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="360" y="70" width="300" height="26" as="geometry" />
        </mxCell>

        <mxCell id="n1" value="🧑 1. Write an issue&#10;(optionally label `claude`)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="115" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="🤖 2. Claude coding agent implements&#10;→ bot-authored branch + PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="380" y="195" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="⚙️ 3. CI: typecheck + tests&#10;⚙️ Visual test: Playwright renders the real&#10;Expo app → screenshots posted on the PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="275" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="n3b" value="🤖 3b. Advisory agents (optional)&#10;visual agent + OWASP security agent&#10;→ findings on PR (non-blocking)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="275" width="200" height="66" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="🧑 GATE 1 — CODE REVIEW &amp; APPROVAL&#10;review diff + screenshots + findings; approve&#10;(bot PR ⇒ a human can approve)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#b85450;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="375" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="⚙️ 5. Merge to main&#10;(impossible without GATE 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="475" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- ============ RELEASE SIDE ============ -->
        <mxCell id="relHdr" value="RELEASE SIDE  (release → store)" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=#eeeeee;rounded=1;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="360" y="555" width="300" height="26" as="geometry" />
        </mxCell>

        <mxCell id="n6" value="🧑 6. Trigger a Release (version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="600" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="n7" value="⚙️ 7. Build 〔MOCK〕&#10;real: fastlane gym / eas build (+ signing, macOS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="665" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="🧑 GATE 2 — RELEASE APPROVAL&#10;`production` environment approves before submit&#10;(the irreversible step)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#b85450;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="745" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="n9" value="⚙️ 9. Submit to stores 〔MOCK〕&#10;real: fastlane deliver/supply · eas submit&#10;→ submission_id, PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="845" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n10" value="🍏 10. Store review 〔SIMULATED〕&#10;async · Apple / Google · NOT your gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="380" y="935" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rej" value="🧑 Rejection loop&#10;opens `store-rejection` issue&#10;→ human fixes → re-release" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="930" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n11" value="⚙️/🧑 11. Release 〔MOCK〕&#10;real: phased/staged rollout&#10;(% = blast-radius dial; human monitors)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="1025" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Edges: main flow -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n3" target="g1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="g1" target="n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n5" target="n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n6" target="n7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n7" target="g2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="g2" target="n9"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n9" target="n10"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="approved" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontColor=#2d7600;" edge="1" parent="1" source="n10" target="n11"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Edges: advisory + rejection -->
        <mxCell id="ea" value="optional" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;" edge="1" parent="1" source="n3" target="n3b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;" edge="1" parent="1" source="n3b" target="g1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erej" value="rejected" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;fontColor=#b85450;" edge="1" parent="1" source="n10" target="rej"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erej2" value="re-release" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;" edge="1" parent="1" source="rej" target="n6"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
