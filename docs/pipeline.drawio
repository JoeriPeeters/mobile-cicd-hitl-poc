          <mxGeometry x="360" y="70" width="300" height="26" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="🧑 1. Ticket (Jira / Linear)&#10;→ optionally hand to the coding agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="380" y="115" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="🤖 2. Coding agent implements&#10;→ bot-authored PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="380" y="195" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="⚙️ 3. CI: lint + typecheck + unit + Detox e2e&#10;⚙️ Visual: Android emulator / iOS sim + Maestro&#10;→ screenshots + pixel-diff regression" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="275" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="p3b" value="🤖 3b. Advisory agents&#10;visual agent (vs Figma) + OWASP&#10;risk routing → findings on PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="275" width="200" height="66" as="geometry" />
        </mxCell>
        <mxCell id="pg1" value="🧑 GATE 1 — CODE REVIEW &amp; APPROVAL&#10;code owners + required checks (CI + visual)&#10;no admin bypass" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#b85450;strokeWidth=3;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="375" width="260" height="66" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="⚙️ 5. Merge queue → main&#10;(re-tests each PR against latest main)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="380" y="475" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- RELEASE SIDE -->
        <mxCell id="prelHdr" value="RELEASE SIDE  (release → store)" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=#eeeeee;rounded=1;strokeColor=#cccccc;" vertex="1" parent="1">
          <mxGeometry x="360" y="555" width="300" height="26" as="geometry" />
